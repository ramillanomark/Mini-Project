    mysqli_query($conn, "INSERT INTO projects (title,description,tech_used,date_added) VALUES ('$t','$d','$u','".date('Y-m-d')."')");
    $msg = "Project added!";
}
if (isset($_POST['update_project'])) {
    $id = (int)$_POST['id'];
