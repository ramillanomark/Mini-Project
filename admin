    mysqli_query($conn, "UPDATE projects SET title='$t',description='$d',tech_used='$u' WHERE id=$id");
    $msg = "Project updated!";
}
if (isset($_GET['del_project'])) {
    mysqli_query($conn, "DELETE FROM projects WHERE id=".(int)$_GET['del_project']);
    header("Location: admin.php?msg=deleted"); exit();
}

if (isset($_POST['add_skill'])) {
